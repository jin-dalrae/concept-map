{
  "name": "concept-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n plugin,ui \"npm:build:plugin -- --watch\" \"vite\"",
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "esbuild src/plugin/controller.ts --bundle --outfile=dist/code.js --target=es2015 --format=iife",
    "build:ui": "vite build",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
