{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["../../node_modules/@figma"],
    "composite": true,
    "rootDir": "..",
    "outDir": "../../dist-tsc/plugin"
  },
  "include": ["./**/*.ts", "../shared/**/*.ts"]
}
